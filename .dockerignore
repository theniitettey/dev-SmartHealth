# ── .dockerignore ─────────────────────────────────────────────
# Prevents sensitive and unnecessary files from being baked into the image

# Environment files — secrets are injected at runtime via docker-compose
.env
.env.*
!.env.example

# Dev tools and local state
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Git and CI
.git/
.github/
.gitignore

# Notebooks and datasets (not needed at runtime)
notebooks/
datasets/
data/

# Docs and other non-runtime files
README.md
*.md
