# ─── Smart Health Sync Environment Configuration ───────────────
FLASK_ENV=development
SECRET_KEY=smarthealthsync-dev-secret-2026
LOG_LEVEL=INFO

# Database connection URL (SQLite fallback is used if omitted)
DATABASE_URL=your-database-url

# Groq API Key (Get a free key at https://console.groq.com/)
GROQ_API_KEY=your-groq-api-key-here

# Super Admin Seed Credentials (Optional - defaults are used if omitted)
ADMIN_EMAIL=your-admin-email
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password

# SMTP Mail (Optional - doctor approval/rejection notifications are skipped if omitted)
# Gmail: use an App Password (myaccount.google.com/apppasswords), MAIL_USERNAME/MAIL_DEFAULT_SENDER = your Gmail address
# Resend: MAIL_SERVER=smtp.resend.com, MAIL_USERNAME=resend, MAIL_PASSWORD=your Resend API key
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password-or-api-key
MAIL_DEFAULT_SENDER=your-smtp-username
