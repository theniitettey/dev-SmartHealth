# ─── Smart Health Sync Environment Configuration ───────────────
FLASK_ENV=development
SECRET_KEY=smarthealthsync-dev-secret-2026
LOG_LEVEL=INFO

# Database connection URL (SQLite fallback is used if omitted)
DATABASE_URL=your-database-url

# Groq API Key (Get a free key at https://console.groq.com/)
GROQ_API_KEY=your-groq-api-key-here

# Super Admin Seed Credentials (Optional - defaults are used if omitted)
ADMIN_EMAIL=your-admin-email
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password
